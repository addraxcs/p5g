# Copy to .env on the Pi and fill in real values.
# Do not commit .env.

# =============================================================================
# INTERFACES
# Three interfaces are in play. Each has a distinct role.
# =============================================================================

# MGMT - eth0, wired ethernet.
# This is how you SSH into the Pi throughout setup.
# The firewall keeps port 22 open on this interface regardless of other changes.
# Do not change this unless you know what you are doing.
MGMT_IF=eth0

# LAN - wlan0, the Pi's built-in wifi radio.
# Downstream clients (phones, laptops) connect to this as an access point.
LAN_IF=wlan0

# WAN - the Huawei E3372 USB dongle.
# Set this AFTER the Pi has packages installed and the dongle is plugged in.
# Run detect_modem.sh to find the right value. Common results:
#   eth1  - HiLink / network mode (Path A, most common)
#   usb0  - HiLink on some kernels (Path A)
#   ppp0  - PPP / serial mode (Path B)
WAN_IF=PENDING

# =============================================================================
# WIFI AP (LAN side)
# =============================================================================

WIFI_SSID=change-me
WIFI_PASSPHRASE=change-me
WIFI_COUNTRY=PENDING
WIFI_CHANNEL=6

# =============================================================================
# LAN SUBNET
# =============================================================================

LAN_GATEWAY=10.77.0.1
LAN_SUBNET=10.77.0.0/24
LAN_SUBNET_MASK=255.255.255.0
DHCP_RANGE_START=10.77.0.50
DHCP_RANGE_END=10.77.0.200
DHCP_LEASE=12h

# =============================================================================
# PPP (Path B only - ignore if WAN_IF=eth1 or usb0)
# =============================================================================

PPP_DEV=/dev/ttyUSB2

# APN for your SIM. Common values:
#   UK:  giffgaff: giffgaff  |  Three: 3internet  |  EE: everywhere  |  Vodafone: wap.vodafone.co.uk  |  O2: mobile.o2.co.uk
#   US:  T-Mobile: fast.t-mobile.com  |  AT&T: phone  |  Mint: wholesale  |  Visible: VSBLINTERNET
#   EU:  most use: internet
APN=PENDING
PPP_USER=
PPP_PASS=

# =============================================================================
# WATCHDOG
# =============================================================================

HEALTHCHECK_TARGET=1.1.1.1
HEALTHCHECK_INTERVAL=60
HEALTHCHECK_FAILURES=3
